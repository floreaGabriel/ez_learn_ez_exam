<mxfile host="app.diagrams.net" type="device">
  <diagram name="Stari proces" id="stari-proces">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="new" value="new" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ready" value="ready" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="220" y="200" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="running" value="running" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="430" y="200" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="waiting" value="waiting / blocked" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="term" value="terminated" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="640" y="200" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="admitted" style="endArrow=classic;html=1;" edge="1" parent="1" source="new" target="ready"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="dispatch" style="endArrow=classic;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="ready" target="running"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="interrupt (cuanta)" style="endArrow=classic;html=1;exitX=0;exitY=0.7;entryX=1;entryY=0.7;" edge="1" parent="1" source="running" target="ready"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="I/O wait" style="endArrow=classic;html=1;" edge="1" parent="1" source="running" target="waiting"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="I/O done" style="endArrow=classic;html=1;" edge="1" parent="1" source="waiting" target="ready"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="exit" style="endArrow=classic;html=1;" edge="1" parent="1" source="running" target="term"><mxGeometry relative="1" as="geometry" /></mxCell>
